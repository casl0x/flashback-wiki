// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum EtatVie {
  EN_VIE
  MORT
  PARTI
  DISPARU
}

enum Role {
  civil
  illegal
}

enum CreatorType {
  ARTISTE
  EDITEUR
}

enum SocialPlatform {
  TWITTER
  TIKTOK
  YOUTUBE
  INSTAGRAM
  TWITCH
  AUTRE
}

model UserProfile {
  id                 String   @id @default(cuid())
  clerkUserId        String   @unique
  pseudo             String?
  onboardingComplete Boolean  @default(false)
  totalPoints        Int      @default(0)
  acceptedCount      Int      @default(0)
  badges             String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  creatorRoles       CreatorRole[]
  socialLinks        SocialLink[]
}

model CreatorRole {
  id            String      @id @default(cuid())
  type          CreatorType
  displayOnWiki Boolean     @default(false)
  status        String      @default("pending")
  bio           String?
  createdAt     DateTime    @default(now())

  userProfileId String
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, type])
  @@map("creator_roles")
}

model SocialLink {
  id            String         @id @default(cuid())
  platform      SocialPlatform
  url           String
  createdAt     DateTime       @default(now())

  userProfileId String
  userProfile   UserProfile    @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@map("social_links")
}

model Version {
  id          String   @id // ex: "V1", "V2"
  label       String
  description String?
  color       String   @default("#8880a8")
  createdAt   DateTime @default(now()) @map("created_at")

  characters Character[]

  @@map("versions")
}

model Player {
  id         String   @id @default(uuid())
  pseudo     String
  stream     Boolean  @default(false)
  lienChaine String?  @map("lien_chaine")
  reseaux    Json     @default("{}")
  badges     String[] @default([]) 
  createdAt  DateTime @default(now()) @map("created_at")

  characters Character[]

  @@map("players")
}

model Character {
  id          String   @id @default(uuid())
  nom         String
  role        Role?
  description String?
  metier      String?
  groupe     String?
  lienReddif  String?  @map("lien_reddif")
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  etatVie EtatVie @default(EN_VIE) @map("etat_vie")

  playerId  String?  @map("player_id")
  player    Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  versionId String?  @map("version_id")
  version   Version? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  // Relations symétriques
  relationsA Relation[] @relation("PersonnageA")
  relationsB Relation[] @relation("PersonnageB")

  locationX Float? @map("location_x")
  locationY Float? @map("location_y")

  suggestions Suggestion[]

  @@map("characters")
}

model Relation {
  id           String   @id @default(uuid())
  typeRelation String?  @map("type_relation")
  typeRelationInverse String?
  createdAt    DateTime @default(now()) @map("created_at")

  personnageAId String    @map("personnage_a")
  personnageA   Character @relation("PersonnageA", fields: [personnageAId], references: [id], onDelete: Cascade)

  personnageBId String    @map("personnage_b")
  personnageB   Character @relation("PersonnageB", fields: [personnageBId], references: [id], onDelete: Cascade)

  @@unique([personnageAId, personnageBId])
  @@map("relations")
}


model Suggestion {
  id          String   @id @default(cuid())
  clerkUserId String?
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  nom         String?
  metier      String?
  groupe      String?
  description String?
  note        String?
  status      String   @default("pending") // pending | accepted | rejected
  createdAt   DateTime @default(now())
}

model ChangelogEntry {
  id        String   @id @default(uuid())
  type      String   // "add_global" | "add_relation" | "add_lieu" | "edit_info" | "edit_relation" | "edit_lieu" | "version"
  label     String   // nom du perso ou de la version
  detail    String?  // info supplémentaire optionnelle
  createdAt DateTime @default(now()) @map("created_at")

  @@map("changelog_entries")
}